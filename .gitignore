# ==========================================
# Gemma 4 MTP Benchmark .gitignore
# ==========================================

# Python Caches & Bytecode
__pycache__/
*.py[cod]
*$py.class

# Environments (Virtualenv, Conda, etc.)
venv/
.venv/
env/
.env/
ENV/

# Local Benchmark Run Data (Excluding public assets)
logs/
*.log
*.csv
raw_profiles/

# Developer Scratchpad Files
scratch/
temp_*.py
test_outputs/

# macOS System Files
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# IDE / Editor Configurations
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.pydevproject

# Hugging Face Local Cache
.cache/huggingface/
